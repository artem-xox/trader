TELEGRAM_API_TOKEN=
# Comma-separated chat IDs; leave empty to allow everyone (dev only)
TELEGRAM_ALLOWED_CHAT_IDS=

# --- Agent ---
AGENT_MAX_ITERATIONS=8
AGENT_APP_URL=http://127.0.0.1:8000

# The agent app traces every turn whenever LANGSMITH_API_KEY is set: a compressed
# single-span trace by default, or the full nested trace on a debug request (Telegram
# /debug, or `debug: true` on /agent/invoke). LANGSMITH_TRACING gates the eval path
# (`make eval TRACE=true`).
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="trader"

OPENAI_API_KEY=
# Stronger model plans; lighter model handles selection/guard/response synthesis.
OPENAI_MODEL_STRONG=gpt-4.1
OPENAI_MODEL_WEAK=gpt-4.1-mini
# LLM-as-judge for evaluation; leave empty to use the strong tier (judge must be at least
# as capable as the agent it grades).
OPENAI_MODEL_EVAL=

TAVILY_API_KEY=